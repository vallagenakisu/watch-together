# WebSocket server URL. Defaults to ws://localhost:8080 if unset.
# In production point this at your deployed/tunneled Node server (use wss:// over https).
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Optional: enables YouTube search. Get one at
# https://console.cloud.google.com/ -> enable "YouTube Data API v3" -> create API key.
# Without it, users can still paste a YouTube URL to choose a video.
YOUTUBE_API_KEY=
